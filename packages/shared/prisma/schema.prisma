/// Joins users to roles, optionally scoped per account. account_id NULL
/// means the role applies tenant-wide (admin staff). account_id NOT NULL
/// means the role applies only when the user is acting on that account
/// (portal contacts).
///
/// Constraints:
///   - At most one tenant-wide row per user (partial unique index on
///     user_id WHERE account_id IS NULL — Prisma can't express this so
///     it lives in the migration SQL).
///   - At most one role per (user, account) pair — Prisma unique on
///     (userId, accountId) which Postgres treats as distinct when one
///     side is NULL, so it allows the tenant-wide row to coexist with
///     per-account rows. The partial index above closes the only gap.
model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  utilityId String   @map("utility_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  accountId String?  @map("account_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user    CisUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role    Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, accountId])
  @@index([accountId])
  @@index([roleId])
  @@index([utilityId, userId])
  @@map("user_role")
}

model TenantModule {
  id        String   @id @default(uuid()) @db.Uuid
  utilityId String   @map("utility_id") @db.Uuid
  moduleKey String   @map("module_key") @db.VarChar(50)
