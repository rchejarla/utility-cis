  suspensionType     String           @map("suspension_type") @db.VarChar(50)
  status             SuspensionStatus @default(PENDING) @map("status")
  startDate          DateTime         @map("start_date") @db.Date
  endDate            DateTime?        @map("end_date") @db.Date
  billingSuspended   Boolean          @default(true) @map("billing_suspended")
  prorateOnStart     Boolean          @default(true) @map("prorate_on_start")
  prorateOnEnd       Boolean          @default(true) @map("prorate_on_end")
  reason             String?          @map("reason") @db.Text
  requestedBy        String?          @map("requested_by") @db.Uuid
  approvedBy         String?          @map("approved_by") @db.Uuid
  ramsNotified       Boolean          @default(false) @map("rams_notified")
  ramsNotifiedAt     DateTime?        @map("rams_notified_at") @db.Timestamptz
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  serviceAgreement ServiceAgreement @relation(fields: [serviceAgreementId], references: [id], onDelete: Cascade)

  @@index([utilityId, serviceAgreementId])
  @@index([utilityId, status])
  @@index([utilityId, startDate, endDate])
