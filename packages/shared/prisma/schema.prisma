// Per-tenant schema definitions for custom fields on extendable
// entities (Customer, Account, Premise, ServiceAgreement, Meter).
// One row per (utility_id, entity_type). The `fields` jsonb column
// holds a FieldDefinition[] array — see packages/shared/src/lib/
// custom-fields.ts for the TypeScript shape. Absence of a row means
// "this tenant has not configured any custom fields for this entity"
// and the customFields column on the corresponding entity row will
// simply be an empty object.
//
// The schema is authoritative: validateCustomFields on the API side
// loads the row, builds a Zod validator from the fields array, and
// uses it to reject unknown keys or type-mismatched values at write
// time. The web form uses the same shape to render inputs.
model CustomFieldSchema {
  id         String   @id @default(uuid()) @db.Uuid
  utilityId  String   @map("utility_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  fields     Json     @default("[]") @map("fields")
  version    Int      @default(1) @map("version")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([utilityId, entityType])
  @@map("custom_field_schema")
}

// Tenant-level configuration for service-hold behaviour. Lives alongside
// TenantTheme/TenantModule. A row is created lazily the first time a flag
// is set; absence of a row means "all defaults".
model TenantConfig {
  id                  String   @id @default(uuid()) @db.Uuid
  utilityId           String   @unique @map("utility_id") @db.Uuid
  requireHoldApproval Boolean  @default(false) @map("require_hold_approval")
  settings            Json     @default("{}") @map("settings")

  // ─── Automation / scheduler config (per spec §3.4) ────────────────
  // Per-tenant control of background-job behavior. Each scheduler
  // gets its own boolean toggle; tenant-local timing inputs drive
  // missed-tick recovery and DST-correct dispatch.
  timezone                    String    @default("UTC") @map("timezone") @db.VarChar(64)
  suspensionEnabled           Boolean   @default(true) @map("suspension_enabled")
  notificationSendEnabled     Boolean   @default(true) @map("notification_send_enabled")
  slaBreachSweepEnabled       Boolean   @default(true) @map("sla_breach_sweep_enabled")
  delinquencyEnabled          Boolean   @default(true) @map("delinquency_enabled")
  delinquencyRunHourLocal     Int       @default(3) @map("delinquency_run_hour_local") @db.SmallInt
  delinquencyLastRunAt        DateTime? @map("delinquency_last_run_at") @db.Timestamptz
  notificationQuietStart      String    @default("22:00") @map("notification_quiet_start") @db.VarChar(5)
  notificationQuietEnd        String    @default("07:00") @map("notification_quiet_end") @db.VarChar(5)
  schedulerAuditRetentionDays Int       @default(365) @map("scheduler_audit_retention_days")

  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("tenant_config")
}

// Reference table for suspension (hold) types. Replaces the old
// SuspensionType enum. utilityId IS NULL means a system-global code that
// every tenant sees; utilityId set means a tenant-specific code. The
// unique constraint lets both coexist — a tenant can override a global
// label by inserting a row with the same code.
model SuspensionTypeDef {
  id                      String   @id @default(uuid()) @db.Uuid
  utilityId               String?  @map("utility_id") @db.Uuid
  code                    String   @db.VarChar(50)
  label                   String   @db.VarChar(100)
  description             String?  @db.Text
  category                String?  @db.VarChar(50)
  sortOrder               Int      @default(100) @map("sort_order")
  isActive                Boolean  @default(true) @map("is_active")
  defaultBillingSuspended Boolean  @default(true) @map("default_billing_suspended")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([utilityId, code])
  @@index([isActive, sortOrder])
  @@map("suspension_type_def")
}

